<div class="puct-layout">
  <app-header />
  
  <div class="puct-container">
    <app-sidebar />
    
    <main class="puct-content">
      <div class="puct-header">
        <div class="header-left">
          <h1>📒 Plan Único de Cuentas Tributario (PUCT)</h1>
          <p>Gestión del plan de cuentas para {{ empresaActiva?.actividad_economica }}</p>
        </div>
        <div class="header-right">
          <button class="btn-secondary" (click)="abrirImportador()">
            📥 Importar PUCT
          </button>
          @if (puedeCrear()) {
            <button class="btn-primary" (click)="abrirFormulario()">
              ➕ Nueva Cuenta
            </button>
          }
        </div>
      </div>

      <!-- Mensaje -->
      @if (mensaje()) {
        <div class="mensaje" [class.success]="mensaje()?.tipo === 'success'" [class.error]="mensaje()?.tipo === 'error'">
          {{ mensaje()?.texto }}
        </div>
      }

      <!-- Filtros -->
      <div class="filtros-card">
        <div class="filtros-grid">
          <div class="filtro-item">
            <label>🔍 Buscar</label>
            <input 
              type="text" 
              [(ngModel)]="busqueda"
              (input)="aplicarFiltros()"
              placeholder="Código o nombre..."
            />
          </div>

          <div class="filtro-item">
            <label>📊 Nivel</label>
            <select [(ngModel)]="filtroNivel" (change)="aplicarFiltros()">
              <option [ngValue]="null">Todos los niveles</option>
              <option [ngValue]="1">Nivel 1</option>
              <option [ngValue]="2">Nivel 2</option>
              <option [ngValue]="3">Nivel 3</option>
              <option [ngValue]="4">Nivel 4</option>
              <option [ngValue]="5">Nivel 5</option>
            </select>
          </div>

          <div class="filtro-item">
            <label>🏷️ Tipo</label>
            <select [(ngModel)]="filtroTipo" (change)="aplicarFiltros()">
              <option [ngValue]="null">Todos los tipos</option>
              <option value="activo">Activo</option>
              <option value="pasivo">Pasivo</option>
              <option value="patrimonio">Patrimonio</option>
              <option value="ingreso">Ingreso</option>
              <option value="gasto">Gasto</option>
            </select>
          </div>

          <div class="filtro-item">
            <button class="btn-clear" (click)="limpiarFiltros()">
              🔄 Limpiar
            </button>
          </div>
        </div>
      </div>

      <!-- Loading -->
      @if (cargando) {
        <div class="loading">
          <div class="spinner"></div>
          <p>Cargando plan de cuentas...</p>
        </div>
      }

      <!-- Tabla de cuentas -->
      @if (!cargando) {
        <div class="tabla-card">
          <div class="tabla-info">
            <span>Total de cuentas: <strong>{{ cuentas.length }}</strong></span>
          </div>

          @if (cuentas.length === 0) {
            <div class="empty-state">
              <span class="empty-icon">📋</span>
              <h3>No hay cuentas registradas</h3>
              <p>Usa el botón "Importar PUCT" para cargar el plan de cuentas oficial</p>
            </div>
          } @else {
            <div class="tabla-responsive">
              <table class="tabla-cuentas">
                <thead>
                  <tr>
                    <th>Nivel</th>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>Naturaleza</th>
                    <th>Imputable</th>
                  </tr>
                </thead>
                <tbody>
                  @for (cuenta of cuentas; track cuenta.id) {
                    <tr [class.nivel-1]="cuenta.nivel === 1"
                        [class.nivel-2]="cuenta.nivel === 2"
                        [class.nivel-3]="cuenta.nivel === 3"
                        [class.nivel-4]="cuenta.nivel === 4"
                        [class.nivel-5]="cuenta.nivel === 5">
                      <td>
                        <span class="badge-nivel">{{ getIconoPorNivel(cuenta.nivel) }}</span>
                      </td>
                      <td>
                        <code class="codigo">{{ cuenta.codigo }}</code>
                      </td>
                      <td class="nombre-col">{{ cuenta.nombre }}</td>
                      <td>
                        <span class="badge-tipo" [style.background-color]="getColorPorTipo(cuenta.tipo)">
                          {{ cuenta.tipo }}
                        </span>
                      </td>
                      <td>{{ cuenta.naturaleza }}</td>
                      <td>
                        @if (cuenta.es_imputable) {
                          <span class="badge-si">✓ Sí</span>
                        } @else {
                          <span class="badge-no">✗ No</span>
                        }
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
          }
        </div>
      }
    </main>
  </div>
</div>

<!-- Modal Importador -->
@if (mostrarImportador()) {
  <div class="modal-overlay" (click)="cerrarImportador()">
    <div class="modal-content" (click)="$event.stopPropagation()">
      <div class="modal-header">
        <h2>📥 Importar Plan de Cuentas (PUCT)</h2>
        <button class="btn-close" (click)="cerrarImportador()">✕</button>
      </div>

      <div class="import-body">
        @if (!resultadoImportacion()) {
          <div class="import-instructions">
            <h3>📋 Instrucciones</h3>
            <ol>
              <li>Descarga la plantilla CSV de ejemplo</li>
              <li>Edita el archivo con tus cuentas o usa el PUCT oficial</li>
              <li>Sube el archivo para importar</li>
            </ol>
            
            <button class="btn-download" (click)="descargarPlantilla()">
              📄 Descargar Plantilla CSV
            </button>
          </div>

          <div class="file-upload">
            <label for="fileInput" class="file-label">
              @if (archivoSeleccionado()) {
                <span class="file-selected">✓ {{ archivoSeleccionado()?.name }}</span>
              } @else {
                <span>📁 Seleccionar archivo CSV</span>
              }
            </label>
            <input 
              id="fileInput"
              type="file" 
              accept=".csv"
              (change)="onArchivoSeleccionado($event)"
              hidden
            />
          </div>

          <div class="modal-footer">
            <button class="btn-secondary" (click)="cerrarImportador()" [disabled]="importando()">
              Cancelar
            </button>
            <button 
              class="btn-primary" 
              (click)="importarPUCT()"
              [disabled]="!archivoSeleccionado() || importando()"
            >
              @if (importando()) {
                <span class="spinner-small"></span>
                Importando...
              } @else {
                Importar
              }
            </button>
          </div>
        } @else {
          <div class="import-result">
            <div class="result-success">
              <span class="result-icon">✅</span>
              <h3>Importación Completada</h3>
            </div>

            <div class="result-stats">
              <div class="stat-item">
                <span class="stat-label">Total procesadas:</span>
                <span class="stat-value">{{ resultadoImportacion().total }}</span>
              </div>
              <div class="stat-item success">
                <span class="stat-label">Importadas:</span>
                <span class="stat-value">{{ resultadoImportacion().importadas }}</span>
              </div>
              <div class="stat-item warning">
                <span class="stat-label">Duplicadas (omitidas):</span>
                <span class="stat-value">{{ resultadoImportacion().duplicadas }}</span>
              </div>
              <div class="stat-item error">
                <span class="stat-label">Errores:</span>
                <span class="stat-value">{{ resultadoImportacion().errores }}</span>
              </div>
            </div>

            <div class="modal-footer">
              <button class="btn-primary" (click)="cerrarImportador()">
                Cerrar
              </button>
            </div>
          </div>
        }
      </div>
    </div>
  </div>
}

<!-- Modal Nueva Cuenta MEJORADO -->
@if (mostrarFormulario()) {
  <div class="modal-overlay" (click)="cerrarFormulario()">
    <div class="modal-content modal-large" (click)="$event.stopPropagation()">
      <div class="modal-header">
        <h2>➕ Nueva Cuenta Nivel 5</h2>
        <button class="btn-close" (click)="cerrarFormulario()">✕</button>
      </div>

      <form (submit)="$event.preventDefault(); crearCuenta()">
        <div class="form-body">
          
          <!-- Paso 1: Seleccionar cuenta padre -->
          <div class="form-section">
            <h3>1️⃣ Seleccionar Cuenta Padre (Nivel 4)</h3>
            <div class="form-group full-width">
              <label>Cuenta Padre *</label>
              <select 
                [(ngModel)]="cuentaPadreSeleccionada"
                (change)="onCuentaPadreChange(cuentaPadreSeleccionada())"
                name="cuentaPadre"
                required
              >
                <option value="">-- Seleccione una cuenta de nivel 4 --</option>
                @for (cuenta of cuentasNivel4; track cuenta.id) {
                  <option [value]="cuenta.codigo">
                    {{ cuenta.codigo }} - {{ cuenta.nombre }}
                  </option>
                }
              </select>
              <small>Seleccione la cuenta padre donde se creará la nueva cuenta</small>
            </div>
          </div>

          <!-- Paso 2: Código generado automáticamente -->
          @if (codigoGenerado()) {
            <div class="form-section">
              <h3>2️⃣ Código Asignado Automáticamente</h3>
              <div class="codigo-preview">
                <code class="codigo-grande">{{ codigoGenerado() }}</code>
                <span class="codigo-info">✓ Código generado automáticamente</span>
              </div>
            </div>

            <!-- Paso 3: Información de la cuenta -->
            <div class="form-section">
              <h3>3️⃣ Información de la Cuenta</h3>
              
              <div class="form-group full-width">
                <label>Nombre de la Cuenta *</label>
                <input 
                  type="text" 
                  [(ngModel)]="nombreCuenta"
                  name="nombre"
                  placeholder="Ej: Banco Nacional de Bolivia"
                  required
                  autofocus
                />
              </div>

              <div class="form-grid-2">
                <div class="form-group">
                  <label>Tipo *</label>
                  <select [(ngModel)]="tipoSeleccionado" name="tipo">
                    <option value="activo">Activo</option>
                    <option value="pasivo">Pasivo</option>
                    <option value="patrimonio">Patrimonio</option>
                    <option value="ingreso">Ingreso</option>
                    <option value="gasto">Gasto</option>
                  </select>
                  <small>Heredado de la cuenta padre</small>
                </div>

                <div class="form-group">
                  <label>Naturaleza *</label>
                  <select [(ngModel)]="naturalezaSeleccionada" name="naturaleza">
                    <option value="deudora">Deudora</option>
                    <option value="acreedora">Acreedora</option>
                  </select>
                  <small>Heredado de la cuenta padre</small>
                </div>
              </div>

              <div class="form-group full-width">
                <label class="checkbox-label">
                  <input 
                    type="checkbox" 
                    [(ngModel)]="esImputable"
                    name="es_imputable"
                  />
                  <span>Es imputable (permite registrar movimientos contables)</span>
                </label>
                <small class="info-box">
                  ℹ️ Las cuentas de nivel 5 normalmente son imputables
                </small>
              </div>
            </div>
          }
        </div>

        <div class="modal-footer">
          <button type="button" class="btn-secondary" (click)="cerrarFormulario()" [disabled]="guardando()">
            Cancelar
          </button>
          <button 
            type="submit" 
            class="btn-primary" 
            [disabled]="!codigoGenerado() || !nombreCuenta() || guardando()"
          >
            @if (guardando()) {
              <span class="spinner-small"></span>
              Guardando...
            } @else {
              ✓ Crear Cuenta
            }
          </button>
        </div>
      </form>
    </div>
  </div>
}
